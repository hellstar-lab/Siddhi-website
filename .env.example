# ── Backend API ────────────────────────────────────────────────────────────────
# URL of the Siddhi Sweets backend (Render deployment)
NEXT_PUBLIC_API_URL=https://siddhi-backend-a5nw.onrender.com

# ── Pexels (server-side only — never expose to client) ─────────────────────────
# Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# ── Site URL (used for QR code generation) ─────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourapp.netlify.app

# ── Contact form WhatsApp fallback ─────────────────────────────────────────────
# Used if the backend /api/restaurant API is unavailable.
# Format: country code + number, no spaces or +  (e.g. 919876543210 for India)
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# ── Admin QR page PIN ──────────────────────────────────────────────────────────
# PIN required to access /admin/qr. Change this to something secret.
NEXT_PUBLIC_ADMIN_PIN=1234
